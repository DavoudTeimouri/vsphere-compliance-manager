# ─────────────────────────────────────────────────────────
# vSphere Compliance Manager — Environment Configuration
# Copy to .env and fill in your values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────
APP_ENV=production
SECRET_KEY=REPLACE_WITH_32_CHAR_RANDOM_STRING
ENCRYPTION_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── Database ─────────────────────────────────────────────
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
DATABASE_URL=postgresql://vcm:REPLACE_WITH_STRONG_PASSWORD@postgres:5432/vcm_db
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ── Redis ────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Admin User (created on first startup) ────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
ADMIN_EMAIL=admin@your-domain.com

# ── LDAP / Active Directory (optional) ───────────────────
LDAP_ENABLED=false
LDAP_SERVER_URL=ldap://dc.example.com:389
LDAP_BASE_DN=DC=example,DC=com
LDAP_BIND_DN=CN=svc-vcm,OU=ServiceAccounts,DC=example,DC=com
LDAP_BIND_PASSWORD=
LDAP_USER_FILTER=(sAMAccountName={username})
LDAP_GROUP_ADMIN=CN=vcm-admins,OU=Groups,DC=example,DC=com
LDAP_GROUP_OPERATOR=CN=vcm-operators,OU=Groups,DC=example,DC=com
LDAP_USE_SSL=false
LDAP_TIMEOUT=10

# ── Analysis ─────────────────────────────────────────────
ANALYSIS_SCHEDULE_CRON=0 2 * * *
ANALYSIS_TIMEOUT_SECONDS=3600
ANALYSIS_MAX_WORKERS=4

# ── File Storage ─────────────────────────────────────────
UPLOAD_PATH=/app/uploads
MAX_UPLOAD_SIZE_MB=5

# ── Logging ──────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json

# ── Frontend ─────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000
VITE_APP_TITLE=vSphere Compliance Manager
