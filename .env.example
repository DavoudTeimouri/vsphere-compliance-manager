# ─────────────────────────────────────────────────────────
# vSphere Compliance Manager — Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────
APP_ENV=production                          # development | staging | production
SECRET_KEY=change-me-to-a-long-random-string-at-least-32-chars
ENCRYPTION_KEY=                             # Leave empty to auto-generate on first run
ACCESS_TOKEN_EXPIRE_MINUTES=480             # 8 hours

# ── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql://vcm:vcm_pass@postgres:5432/vcm_db
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ── Redis ────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Initial Admin Seed ───────────────────────────────────
# These only apply on first startup (when no users exist).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=VCM@admin2024!
ADMIN_EMAIL=admin@example.com

# ── LDAP / Active Directory ───────────────────────────────
LDAP_ENABLED=false
LDAP_SERVER_URL=ldap://dc.example.com:389   # ldaps:// for SSL
LDAP_BASE_DN=DC=example,DC=com
LDAP_BIND_DN=CN=svc-vcm,OU=ServiceAccounts,DC=example,DC=com
LDAP_BIND_PASSWORD=
LDAP_USER_FILTER=(sAMAccountName={username})
LDAP_GROUP_ADMIN=CN=vcm-admins,OU=Groups,DC=example,DC=com
LDAP_GROUP_OPERATOR=CN=vcm-operators,OU=Groups,DC=example,DC=com
LDAP_USE_SSL=false
LDAP_TIMEOUT=10

# ── Analysis ─────────────────────────────────────────────
ANALYSIS_SCHEDULE_CRON=0 2 * * *            # Daily at 02:00 AM
ANALYSIS_TIMEOUT_SECONDS=3600
ANALYSIS_MAX_WORKERS=4

# ── File Storage (for logos, exports) ────────────────────
UPLOAD_PATH=/app/uploads
MAX_UPLOAD_SIZE_MB=5

# ── Logging ──────────────────────────────────────────────
LOG_LEVEL=INFO                              # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json                             # json | text

# ── Frontend (build-time) ────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000
VITE_APP_TITLE=vSphere Compliance Manager
